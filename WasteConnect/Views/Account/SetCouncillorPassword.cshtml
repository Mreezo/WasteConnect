@model WasteConnect.ViewModel.CounsellorPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Create Password";
}

<div class="password-container">

    <div class="password-card">

        <img src="~/images/logo.png"
             class="logo"
             alt="WasteConnect"/>

        <h2>Create Your Password</h2>

        <p>
            Welcome to WasteConnect.

            Please create a secure password to activate
            your Councillor account.
        </p>

        <form asp-action="SetCouncillorPassword"
              method="post">

            @Html.AntiForgeryToken()

            <input asp-for="UserId" type="hidden"/>
            <input asp-for="Token" type="hidden"/>

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="form-group">

                <label>Password</label>

                <input asp-for="Password"
                       class="form-control"/>

                <span asp-validation-for="Password"
                      class="text-danger"></span>

            </div>

            <div class="form-group">

                <label>Confirm Password</label>

                <input asp-for="ConfirmPassword"
                       class="form-control"/>

                <span asp-validation-for="ConfirmPassword"
                      class="text-danger"></span>

            </div>

            <button type="submit"
                    class="btn-create">

                Create Password

            </button>

        </form>

    </div>

</div>

<style>

    .password-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 40px;
        background: #f4f7fb;
    }

    .password-card {
        width: 430px;
        background: white;
        padding: 40px;
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,.08);
    }

    .logo {
        display: block;
        width: 80px;
        margin: auto;
        margin-bottom: 20px;
    }

    .password-card h2 {
        text-align: center;
        font-weight: 700;
        margin-bottom: 10px;
        color: #133B5C;
    }

    .password-card p {
        text-align: center;
        margin-bottom: 30px;
        color: #777;
        line-height: 1.6;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-control {
        height: 50px;
        border-radius: 10px;
    }

    .btn-create {
        width: 100%;
        height: 50px;
        background: #198754;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-create:hover {
            background: #146c43;
        }

</style>