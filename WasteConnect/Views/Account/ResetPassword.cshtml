@model WasteConnect.ViewModels.ResetPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password";
}

<div class="auth-page">
    <div class="auth-overlay"></div>

    <div class="auth-card">
        <h2>Change Password</h2>

        <p>Create a new password for your Waste Connect account.</p>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="form-group">
                <label>New Password</label>
                <input asp-for="NewPassword" class="form-control" placeholder="Enter new password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Confirm New Password</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="auth-btn">
                Change Password
            </button>

            <div class="auth-links">
                <a asp-action="Login">Back to Login</a>
            </div>
        </form>
    </div>
</div>