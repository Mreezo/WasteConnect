@model WasteConnect.ViewModels.ForgotPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-page">
    <div class="auth-overlay"></div>

    <div class="auth-card">
        <h2>Forgot Password</h2>

        <p>Enter the email address you used when signing up.</p>

        <form id="forgotPasswordForm"
              asp-action="ForgotPassword"
              method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label>Email Address</label>
                <input asp-for="Email"
                       id="resetEmail"
                       class="form-control"
                       placeholder="Enter your email address" />

                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button id="sendCodeBtn"
                    type="button"
                    class="send-code-btn">
                <span>📧</span>
                Send Verification Code
            </button>

            <div class="auth-links">
                <a asp-action="Login">Back to Login</a>
            </div>
        </form>
    </div>
</div>

<div id="verifyCodeModal" class="verify-modal">
    <div class="verify-modal-box">

        <img src="~/images/logo.png" class="verify-logo" />

        <h2>Verify Your Email</h2>

        <p>
            We've sent a 6-digit verification code to your email.
        </p>

        <div class="code-inputs">
            <input maxlength="1" class="code-box" />
            <input maxlength="1" class="code-box" />
            <input maxlength="1" class="code-box" />
            <input maxlength="1" class="code-box" />
            <input maxlength="1" class="code-box" />
            <input maxlength="1" class="code-box" />
        </div>

        <button id="verifyCodeBtn"
                type="button"
                class="send-code-btn">
            Verify Code
        </button>

        <div class="verify-footer">
            <span id="countdown">Code expires in 10:00</span>
            <a href="#" id="resendCode">Resend Code</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const codeBoxes = document.querySelectorAll(".code-box");
        const modal = document.getElementById("verifyCodeModal");
        const sendCodeBtn = document.getElementById("sendCodeBtn");
        const verifyCodeBtn = document.getElementById("verifyCodeBtn");

        codeBoxes.forEach((box, index) => {
            box.addEventListener("input", function () {
                this.value = this.value.replace(/[^0-9]/g, "");

                if (this.value.length === 1 && index < codeBoxes.length - 1) {
                    codeBoxes[index + 1].focus();
                }
            });

            box.addEventListener("keydown", function (e) {
                if (e.key === "Backspace" && this.value === "" && index > 0) {
                    codeBoxes[index - 1].focus();
                }
            });
        });

        document.querySelector(".code-inputs").addEventListener("paste", function (e) {
            e.preventDefault();

            const paste = (e.clipboardData || window.clipboardData)
                .getData("text")
                .replace(/\D/g, "")
                .substring(0, 6);

            [...paste].forEach((digit, i) => {
                if (codeBoxes[i]) {
                    codeBoxes[i].value = digit;
                }
            });

            if (paste.length === 6) {
                codeBoxes[5].focus();
            }
        });

        sendCodeBtn.addEventListener("click", async function () {
            const form = document.getElementById("forgotPasswordForm");
            const formData = new FormData(form);

            sendCodeBtn.disabled = true;
            sendCodeBtn.innerHTML = "Sending...";

            const response = await fetch(form.action, {
                method: "POST",
                body: formData
            });

            const result = await response.json();

            sendCodeBtn.disabled = false;
            sendCodeBtn.innerHTML = "<span>📧</span> Send Verification Code";

            if (result.success) {
                modal.classList.add("show");
                codeBoxes[0].focus();
                startCountdown();
            } else {
                alert(result.message);
            }
        });

        verifyCodeBtn.addEventListener("click", async function () {
            const email = document.getElementById("resetEmail").value;

            let code = "";
            codeBoxes.forEach(box => {
                code += box.value;
            });

            if (code.length !== 6) {
                alert("Please enter the full 6-digit code.");
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const formData = new FormData();
            formData.append("email", email);
            formData.append("code", code);
            formData.append("__RequestVerificationToken", token);

            const response = await fetch("/Account/VerifyResetCodeAjax", {
                method: "POST",
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = result.redirectUrl;
            } else {
                alert(result.message);
            }
        });

        let timer;

        function startCountdown() {
            clearInterval(timer);

            let seconds = 600;
            const countdown = document.getElementById("countdown");

            timer = setInterval(() => {
                let min = Math.floor(seconds / 60);
                let sec = seconds % 60;

                countdown.innerText =
                    `Code expires in ${min}:${sec.toString().padStart(2, '0')}`;

                seconds--;

                if (seconds < 0) {
                    clearInterval(timer);
                    countdown.innerText = "Verification code expired";
                }
            }, 1000);
        }
    </script>
}