@model WasteConnect.ViewModels.CompanyProfileViewModel

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Edit Company Profile";
}

<div class="company-profile-modern">

    <div class="company-profile-header">
        <div class="company-avatar-section">
            <div class="company-avatar-large">
                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" />
                }
                else
                {
                    <span>@Model.CompanyName.Substring(0, 1).ToUpper()</span>
                }
            </div>
        </div>

        <div class="company-profile-title">
            <h2>Edit Company Profile</h2>
            <p>Update your company contact and service details.</p>
        </div>
    </div>

    <form asp-controller="Company"
          asp-action="EditCompanyProfile"
          method="post"
          class="company-edit-form">

        @Html.AntiForgeryToken()

        <input asp-for="Id" type="hidden" />
        <input asp-for="UserId" type="hidden" />
        <input asp-for="ProfileImageUrl" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">

            <div class="form-box">
                <label asp-for="CompanyName"></label>
                <input asp-for="CompanyName" />
                <span asp-validation-for="CompanyName" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="RegistrationNumber"></label>
                <input asp-for="RegistrationNumber" />
                <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="ContactPerson"></label>
                <input asp-for="ContactPerson" />
                <span asp-validation-for="ContactPerson" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="Email"></label>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="ServiceArea"></label>
                <input asp-for="ServiceArea" />
                <span asp-validation-for="ServiceArea" class="text-danger"></span>
            </div>

        </div>

        <button type="submit" class="submit-company-btn">
            Save Changes
        </button>

        <a asp-controller="Company"
           asp-action="CompanyProfile"
           class="back-link">
            Cancel
        </a>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}