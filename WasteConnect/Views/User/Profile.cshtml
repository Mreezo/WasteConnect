@model WasteConnect.ViewModels.UserProfileViewModel

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Profile";
}

<div class="user-profile-page">

    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="success-alert">
            @TempData["ProfileSuccess"]
        </div>
    }

    <form asp-controller="User"
          asp-action="Profile"
          method="post"
          enctype="multipart/form-data"
          class="profile-edit-card">

        @Html.AntiForgeryToken()

        <div class="profile-header-section">

            <div class="profile-avatar-large">
                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" />
                }
                else
                {
                    <span>@Model.FullName.Substring(0, 1).ToUpper()</span>
                }
            </div>

            <div>
                <h2>@Model.FullName</h2>
                <p>@Model.Email</p>

                <label class="upload-profile-btn">
                    Change Profile Picture
                    <input asp-for="ProfileImage"
                           type="file"
                           accept="image/*" />
                </label>
            </div>

        </div>

        <div class="form-grid">

            <div class="form-box">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label asp-for="HomeAddress"></label>
                <input asp-for="HomeAddress" />
                <span asp-validation-for="HomeAddress" class="text-danger"></span>
            </div>

            <div class="form-box">
                <label>Email</label>
                <input asp-for="Email" readonly />
            </div>

        </div>

        <button type="submit" class="submit-company-btn">
            Save Profile
        </button>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}