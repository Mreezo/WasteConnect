@model WasteConnect.ViewModel.CreateCouncillorViewModel;

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Create Councillor";
}

<div class="create-councillor-page">

    <div class="portal-page-header">
        <div>
            <h2>Create Councillor Account</h2>
            <p>
                Add an official ward councillor and send them a secure email
                invitation to create their own password.
            </p>
        </div>

        <a asp-controller="Admin"
           asp-action="ManageCouncillors"
           class="back-councillors-btn">
            ← Back to Councillors
        </a>
    </div>

    <div class="create-councillor-layout">

        <div class="create-councillor-form-card">

            <div class="form-card-header">
                <div class="form-header-icon">
                    <span>👤</span>
                </div>

                <div>
                    <h3>Councillor Details</h3>
                    <p>
                        Enter the official information for the councillor account.
                    </p>
                </div>
            </div>

            <form asp-controller="Admin"
                  asp-action="CreateCouncillor"
                  method="post"
                  class="councillor-form">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="validation-summary"></div>

                <div class="form-section">

                    <div class="section-title">
                        <h4>Personal Information</h4>
                        <p>Basic details used to identify the councillor.</p>
                    </div>

                    <div class="form-grid">

                        <div class="form-group full-width">
                            <label asp-for="FullName"></label>

                            <div class="input-wrapper">
                                <span class="input-icon">👤</span>

                                <input asp-for="FullName"
                                       class="form-control"
                                       placeholder="Enter councillor's full name"
                                       autocomplete="name" />
                            </div>

                            <span asp-validation-for="FullName"
                                  class="field-validation"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email"></label>

                            <div class="input-wrapper">
                                <span class="input-icon">✉</span>

                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="councillor@example.gov.za"
                                       autocomplete="email" />
                            </div>

                            <span asp-validation-for="Email"
                                  class="field-validation"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="PhoneNumber"></label>

                            <div class="input-wrapper">
                                <span class="input-icon">☎</span>

                                <input asp-for="PhoneNumber"
                                       class="form-control"
                                       placeholder="071 234 5678"
                                       autocomplete="tel" />
                            </div>

                            <span asp-validation-for="PhoneNumber"
                                  class="field-validation"></span>
                        </div>

                    </div>
                </div>

                <div class="form-section">

                    <div class="section-title">
                        <h4>Ward Assignment</h4>
                        <p>
                            This determines which community reports the councillor
                            will eventually be allowed to access.
                        </p>
                    </div>

                    <div class="form-grid">

                        <div class="form-group">
                            <label asp-for="WardNumber"></label>

                            <div class="input-wrapper">
                                <span class="input-icon">#</span>

                                <input asp-for="WardNumber"
                                       type="number"
                                       min="1"
                                       max="100"
                                       class="form-control"
                                       placeholder="Example: 23" />
                            </div>

                            <span asp-validation-for="WardNumber"
                                  class="field-validation"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="PositionTitle"></label>

                            <div class="input-wrapper">
                                <span class="input-icon">⚖</span>

                                <input asp-for="PositionTitle"
                                       class="form-control"
                                       placeholder="Ward Councillor" />
                            </div>

                            <span asp-validation-for="PositionTitle"
                                  class="field-validation"></span>
                        </div>

                    </div>
                </div>

                <div class="invitation-notice">
                    <div class="notice-icon">✉</div>

                    <div>
                        <strong>Password setup invitation</strong>

                        <p>
                            The administrator will not create the councillor's
                            password. After this profile is created, WasteConnect
                            will email the councillor a secure link to create their
                            own password.
                        </p>
                    </div>
                </div>

                <div class="form-actions">

                    <a asp-controller="Admin"
                       asp-action="ManageCouncillors"
                       class="cancel-councillor-btn">
                        Cancel
                    </a>

                    <button type="submit"
                            id="createCouncillorButton"
                            class="create-councillor-btn">
                        <span class="button-icon">＋</span>
                        <span class="button-text">Create Councillor</span>
                    </button>

                </div>

            </form>

        </div>

        <aside class="councillor-info-card">

            <div class="info-card-icon">
                <span>🛡</span>
            </div>

            <h3>Secure Account Creation</h3>

            <p>
                Councillor accounts are created by authorised administrators
                instead of through public registration.
            </p>

            <div class="account-process">

                <div class="process-item">
                    <span class="process-number">1</span>

                    <div>
                        <strong>Admin creates profile</strong>
                        <p>
                            The councillor's official details and ward number are
                            recorded.
                        </p>
                    </div>
                </div>

                <div class="process-item">
                    <span class="process-number">2</span>

                    <div>
                        <strong>Email invitation is sent</strong>
                        <p>
                            A secure password setup link is delivered to the
                            councillor's email address.
                        </p>
                    </div>
                </div>

                <div class="process-item">
                    <span class="process-number">3</span>

                    <div>
                        <strong>Councillor creates password</strong>
                        <p>
                            Only the councillor knows and controls their login
                            password.
                        </p>
                    </div>
                </div>

                <div class="process-item">
                    <span class="process-number">4</span>

                    <div>
                        <strong>Account becomes ready</strong>
                        <p>
                            The councillor can sign in once their password has
                            been created.
                        </p>
                    </div>
                </div>

            </div>

        </aside>

    </div>

</div>

<style>
    .create-councillor-page {
        width: 100%;
        padding-bottom: 40px;
    }

    .portal-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 24px;
    }

    .portal-page-header h2 {
        margin: 0 0 7px;
        color: #0f2742;
        font-size: 28px;
        font-weight: 800;
    }

    .portal-page-header p {
        max-width: 720px;
        margin: 0;
        color: #64748b;
        font-size: 15px;
        line-height: 1.6;
    }

    .back-councillors-btn {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 18px;
        border: 1px solid #d8e2eb;
        border-radius: 10px;
        background: #ffffff;
        color: #334155;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .back-councillors-btn:hover {
        border-color: #1f8f4d;
        color: #1f8f4d;
        transform: translateY(-1px);
    }

    .create-councillor-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 24px;
        align-items: start;
    }

    .create-councillor-form-card,
    .councillor-info-card {
        border: 1px solid #e3eaf0;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 12px 35px rgba(15, 39, 66, 0.06);
    }

    .create-councillor-form-card {
        overflow: hidden;
    }

    .form-card-header {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 24px 28px;
        border-bottom: 1px solid #e8eef3;
        background: linear-gradient(135deg, #f7fbf8 0%, #f8fbff 100%);
    }

    .form-header-icon {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 15px;
        background: #e6f5eb;
        font-size: 24px;
    }

    .form-card-header h3 {
        margin: 0 0 5px;
        color: #102a43;
        font-size: 20px;
        font-weight: 800;
    }

    .form-card-header p {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .councillor-form {
        padding: 28px;
    }

    .form-section + .form-section {
        margin-top: 30px;
        padding-top: 28px;
        border-top: 1px solid #edf1f4;
    }

    .section-title {
        margin-bottom: 20px;
    }

    .section-title h4 {
        margin: 0 0 5px;
        color: #102a43;
        font-size: 16px;
        font-weight: 800;
    }

    .section-title p {
        margin: 0;
        color: #64748b;
        font-size: 13px;
        line-height: 1.5;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
    }

    .form-group {
        min-width: 0;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #334155;
        font-size: 14px;
        font-weight: 700;
    }

    .input-wrapper {
        position: relative;
    }

    .input-icon {
        position: absolute;
        top: 50%;
        left: 15px;
        z-index: 1;
        transform: translateY(-50%);
        color: #78909c;
        font-size: 15px;
        pointer-events: none;
    }

    .form-control {
        width: 100%;
        min-height: 48px;
        padding: 11px 14px 11px 43px;
        border: 1px solid #d8e2eb;
        border-radius: 11px;
        outline: none;
        background: #ffffff;
        color: #102a43;
        font-family: inherit;
        font-size: 14px;
        transition: 0.2s ease;
        box-sizing: border-box;
    }

    .form-control::placeholder {
        color: #9aa9b7;
    }

    .form-control:focus {
        border-color: #1f8f4d;
        box-shadow: 0 0 0 4px rgba(31, 143, 77, 0.1);
    }

    .validation-summary {
        margin-bottom: 20px;
        border-radius: 10px;
        color: #b42318;
        font-size: 14px;
    }

    .validation-summary ul {
        margin: 0;
        padding: 14px 18px 14px 36px;
        border: 1px solid #fecaca;
        border-radius: 10px;
        background: #fff1f2;
    }

    .validation-summary:empty {
        display: none;
    }

    .field-validation {
        display: block;
        min-height: 18px;
        margin-top: 6px;
        color: #dc2626;
        font-size: 12px;
    }

    .invitation-notice {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-top: 28px;
        padding: 17px;
        border: 1px solid #bfe2cc;
        border-radius: 13px;
        background: #f1faf4;
    }

    .notice-icon {
        width: 38px;
        height: 38px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 11px;
        background: #dff3e6;
        color: #17713d;
        font-size: 18px;
    }

    .invitation-notice strong {
        display: block;
        margin-bottom: 4px;
        color: #176437;
        font-size: 14px;
    }

    .invitation-notice p {
        margin: 0;
        color: #466555;
        font-size: 13px;
        line-height: 1.6;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid #edf1f4;
    }

    .cancel-councillor-btn,
    .create-councillor-btn {
        min-height: 47px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 11px;
        padding: 0 21px;
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .cancel-councillor-btn {
        border: 1px solid #d8e2eb;
        background: #ffffff;
        color: #475569;
    }

    .cancel-councillor-btn:hover {
        border-color: #9fb0bf;
        color: #102a43;
    }

    .create-councillor-btn {
        gap: 7px;
        border: none;
        background: linear-gradient(135deg, #1f8f4d, #16703d);
        color: #ffffff;
        box-shadow: 0 8px 18px rgba(31, 143, 77, 0.2);
    }

    .create-councillor-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(31, 143, 77, 0.26);
    }

    .create-councillor-btn:disabled {
        opacity: 0.7;
        cursor: wait;
        transform: none;
    }

    .button-icon {
        font-size: 18px;
        line-height: 1;
    }

    .councillor-info-card {
        position: sticky;
        top: 20px;
        padding: 27px;
    }

    .info-card-icon {
        width: 54px;
        height: 54px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
        border-radius: 16px;
        background: #e7f0ff;
        font-size: 25px;
    }

    .councillor-info-card h3 {
        margin: 0 0 10px;
        color: #102a43;
        font-size: 19px;
        font-weight: 800;
    }

    .councillor-info-card > p {
        margin: 0 0 24px;
        color: #64748b;
        font-size: 14px;
        line-height: 1.65;
    }

    .account-process {
        display: flex;
        flex-direction: column;
        gap: 19px;
    }

    .process-item {
        display: flex;
        align-items: flex-start;
        gap: 13px;
    }

    .process-number {
        width: 30px;
        height: 30px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: #edf6f0;
        color: #1b7842;
        font-size: 13px;
        font-weight: 900;
    }

    .process-item strong {
        display: block;
        margin-bottom: 3px;
        color: #243b53;
        font-size: 13px;
    }

    .process-item p {
        margin: 0;
        color: #7b8b9a;
        font-size: 12px;
        line-height: 1.5;
    }

    @@media (max-width: 1050px) {
        .create-councillor-layout {
            grid-template-columns: 1fr;
        }

        .councillor-info-card {
            position: static;
        }
    }

    @@media (max-width: 700px) {
        .portal-page-header {
            flex-direction: column;
        }

        .back-councillors-btn {
            width: 100%;
        }

        .form-card-header,
        .councillor-form,
        .councillor-info-card {
            padding: 20px;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: auto;
        }

        .form-actions {
            flex-direction: column-reverse;
        }

        .cancel-councillor-btn,
        .create-councillor-btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const councillorForm = document.querySelector(".councillor-form");
        const createButton = document.getElementById("createCouncillorButton");

        if (councillorForm && createButton) {
            councillorForm.addEventListener("submit", function () {
                if (!councillorForm.checkValidity()) {
                    return;
                }

                createButton.disabled = true;

                createButton.querySelector(".button-text").innerText =
                    "Creating Account...";
            });
        }
    </script>
}